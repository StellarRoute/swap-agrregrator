# Template only — never commit a real filled-in secret.yaml. Populate via your secrets
# manager (e.g. `kubectl create secret generic ... --from-literal=...`, External Secrets
# Operator, or Sealed Secrets) and apply that instead of editing/committing this file.
apiVersion: v1
kind: Secret
metadata:
  name: stellarhydra-secrets
  namespace: stellarhydra
type: Opaque
stringData:
  DATABASE_URL: "postgresql://USER:PASSWORD@HOST:5432/stellarhydra"
  REDIS_URL: "redis://HOST:6379/0"
  CELERY_BROKER_URL: "redis://HOST:6379/0"
  CELERY_RESULT_BACKEND: "redis://HOST:6379/1"
  STELLARROUTE_CONTRACT_ID: ""
  DRIPS_API_KEY: ""
  DRIPS_ACCOUNT_ID: ""
  SENTIMENT_API_BASE_URL: ""
  SENTIMENT_API_KEY: ""
  MARKET_DATA_API_BASE_URL: ""
  MARKET_DATA_API_KEY: ""
  ADMIN_API_KEY: ""
