# Copy to .env and fill in real values. Never commit the real .env file.

# --- Core service ---
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql://stellarhydra:stellarhydra@localhost:5432/stellarhydra

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Stellar / Soroban ---
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLARROUTE_CONTRACT_ID=                # set once a deployed contract ID is available

# --- Drips Wave API ---
DRIPS_API_BASE_URL=https://api.drips.network
DRIPS_API_KEY=
DRIPS_ACCOUNT_ID=
USE_MOCK_DRIPS_CLIENT=true               # flip to false once real Drips sandbox access is confirmed

# --- External signal providers ---
SENTIMENT_API_BASE_URL=
SENTIMENT_API_KEY=
MARKET_DATA_API_BASE_URL=
MARKET_DATA_API_KEY=
USE_MOCK_SIGNAL_PROVIDER=true            # flip to false once a concrete provider is selected (see PRD Open Question #2)

# --- Risk limits ---
RISK_SCORE_THRESHOLD=0.65
MAX_STREAM_DELTA_PER_CYCLE=1000
MAX_PATH_CAPITAL_PCT=0.25
REBALANCE_COOLDOWN_SECONDS=300
KILL_SWITCH_ENGAGED=false

# --- Polling ---
POOL_POLL_INTERVAL_SECONDS=30
SIGNAL_POLL_INTERVAL_SECONDS=30

# --- Admin API (Phase 3) ---
ADMIN_API_KEY=                           # required to call /audit-log, /debug/metrics, /kill-switch/*
EXECUTOR_FAILURE_ALERT_THRESHOLD=3
